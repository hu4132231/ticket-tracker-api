    {
      "name": "TC-TK-003 - Get Created Ticket - baseline",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let responseJson = null;\r",
              "let jsonParseError = null;\r",
              "\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (error) {\r",
              "    jsonParseError = error;\r",
              "}\r",
              "\r",
              "pm.test(\"Response body is valid JSON\", function () {\r",
              "    pm.expect(\r",
              "        jsonParseError,\r",
              "        jsonParseError ? jsonParseError.message : \"Response should be valid JSON\"\r",
              "    ).to.equal(null);\r",
              "});\r",
              "\r",
              "if (responseJson !== null) {\r",
              "    const expectedTicketId = Number(\r",
              "        pm.environment.get(\"ticket_id\")\r",
              "    );\r",
              "\r",
              "    pm.test(\"Returned ticket id matches saved ticket_id\", function () {\r",
              "        pm.expect(\r",
              "            responseJson.id,\r",
              "            \"Returned id should match the ticket created in the previous request\"\r",
              "        ).to.equal(expectedTicketId);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Response contains required ticket fields\", function () {\r",
              "        const requiredFields = [\r",
              "            \"id\",\r",
              "            \"title\",\r",
              "            \"description\",\r",
              "            \"status\",\r",
              "            \"created_at\",\r",
              "            \"updated_at\"\r",
              "        ];\r",
              "\r",
              "        requiredFields.forEach(function (field) {\r",
              "            pm.expect(\r",
              "                responseJson,\r",
              "                \"Response is missing required field: \" + field\r",
              "            ).to.have.property(field);\r",
              "        });\r",
              "    });\r",
              "\r",
              "    pm.test(\"Ticket fields have correct data types\", function () {\r",
              "        pm.expect(responseJson.id, \"id should be a number\").to.be.a(\"number\");\r",
              "        pm.expect(responseJson.title, \"title should be a string\").to.be.a(\"string\");\r",
              "        pm.expect(\r",
              "            responseJson.description,\r",
              "            \"description should be a string\"\r",
              "        ).to.be.a(\"string\");\r",
              "        pm.expect(responseJson.status, \"status should be a string\").to.be.a(\"string\");\r",
              "        pm.expect(\r",
              "            responseJson.created_at,\r",
              "            \"created_at should be a string\"\r",
              "        ).to.be.a(\"string\");\r",
              "        pm.expect(\r",
              "            responseJson.updated_at,\r",
              "            \"updated_at should be a string\"\r",
              "        ).to.be.a(\"string\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"New ticket has open status\", function () {\r",
              "        pm.expect(responseJson.status).to.equal(\"open\");\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
