    {
      "name": "TC-TK-002 - Create Ticket - baseline",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "let responseJson = null;\r",
              "let jsonParseError = null;\r",
              "\r",
              "try {\r",
              "    responseJson = pm.response.json();\r",
              "} catch (error) {\r",
              "    jsonParseError = error;\r",
              "}\r",
              "\r",
              "pm.test(\"Response body is valid JSON\", function () {\r",
              "    pm.expect(\r",
              "        jsonParseError,\r",
              "        jsonParseError ? jsonParseError.message : \"Response should be valid JSON\"\r",
              "    ).to.equal(null);\r",
              "});\r",
              "\r",
              "if (responseJson !== null) {\r",
              "    pm.test(\"Response contains a numeric ticket id\", function () {\r",
              "        pm.expect(\r",
              "            responseJson,\r",
              "            \"Response should contain an id field\"\r",
              "        ).to.have.property(\"id\");\r",
              "\r",
              "        pm.expect(\r",
              "            responseJson.id,\r",
              "            \"Ticket id should have the expected data type\"\r",
              "        ).to.be.a(\"number\");\r",
              "    });\r",
              "\r",
              "    if (typeof responseJson.id === \"number\") {\r",
              "        pm.environment.set(\"ticket_id\", responseJson.id);\r",
              "    }\r",
              "\r",
              "    pm.test(\"Ticket id is saved to the environment\", function () {\r",
              "        const savedTicketId = Number(\r",
              "            pm.environment.get(\"ticket_id\")\r",
              "        );\r",
              "\r",
              "        pm.expect(\r",
              "            savedTicketId,\r",
              "            \"Saved ticket_id should match the response id\"\r",
              "        ).to.equal(responseJson.id);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [],
            "type": "text/javascript"
          }
